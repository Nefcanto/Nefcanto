@{
    if (ViewBag.Title == null)
    {
        ViewBag.Title = Holism.Framework.Config.GetSetting("Brand") + " - " + Holism.Framework.Config.GetSetting("Slogan");
    }

}
@section CustomHeaders {
    <partial name="GoogleAnalytics" />
}
@section Styles {
    <link href="/styles/all.css" type="text/css" rel="stylesheet" />
}
@section Scripts {
    @RenderSection("Scripts", false)
}
@RenderBody()